# =============================================================================
# Makefile Cocotb + Icarus per HDMI framebuffer capture
# =============================================================================

# -----------------------------------------------------------------------------
# Simulator selection
# -----------------------------------------------------------------------------
SIM = icarus
TOPLEVEL_LANG = verilog

# -----------------------------------------------------------------------------
# Project paths
# -----------------------------------------------------------------------------
SRC_DIR = ../src

# -----------------------------------------------------------------------------
# RTL source files
# -----------------------------------------------------------------------------
VERILOG_SOURCES = \
    $(SRC_DIR)/TOP.v \
    $(SRC_DIR)/TMDS_encoder.v \
    $(SRC_DIR)/framebuffer.v \
    $(SRC_DIR)/framebuffer_video_pipeline.v \
    $(SRC_DIR)/rgb332_to_rgb888.v \
    $(SRC_DIR)/serializer_10_1.v \
    $(SRC_DIR)/video_timing.v \
    $(SRC_DIR)/gowin_primitives_stub.v

# -----------------------------------------------------------------------------
# Top-level HDL module
# -----------------------------------------------------------------------------
TOPLEVEL = hdmi_top

# -----------------------------------------------------------------------------
# Cocotb Python test module
# -----------------------------------------------------------------------------
COCOTB_TEST_MODULES = test_hdmi_framebuffer_capture

# -----------------------------------------------------------------------------
# Simulation build directory
# -----------------------------------------------------------------------------
SIM_BUILD = sim_build

# -----------------------------------------------------------------------------
# Compile arguments
#
# -DSIMULATION: enable the simulation branch in your RTL
# -----------------------------------------------------------------------------
COMPILE_ARGS += -DSIMULATION

# -----------------------------------------------------------------------------
# Waveform dump
#
# To capture the framebuffer, it is best to set this to 0.
# If you want to debug in GTKWave, set:
#   WAVES = 1
# but the simulation will be slower.
# -----------------------------------------------------------------------------
WAVES = 0

# -----------------------------------------------------------------------------
# Include Cocotb make system
# -----------------------------------------------------------------------------
include $(shell cocotb-config --makefiles)/Makefile.sim